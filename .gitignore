# ====================== 【通用系统临时文件 忽略不上传】======================
# 系统垃圾文件、缓存、日志，全部不需要备份上传
.DS_Store
*.log
logs/
tmp/
temp/

# ====================== 【Node.js (OpenClaw运行环境) 依赖文件 忽略不上传】======================
# OpenClaw的第三方依赖包，本地安装生成，不需要上传仓库
node_modules/
npm-debug.log*
dist/
build/

# ====================== 【Python环境 缓存/虚拟环境 忽略不上传】======================
# Python运行缓存、本地虚拟环境，全部不上传
__pycache__/
*.py[cod]
.venv/
venv/

# ====================== 【本地私密配置文件 绝对忽略不上传】======================
# 本地真实环境变量、真实配置文件，有账号路径信息，不上传GitHub防止泄露
.env
.env.local
.env.production
config.env
config.yaml
local.conf

# ====================== 【Hailo加速卡SDK 本地缓存文件 忽略不上传】======================
# Hailo驱动本地下载缓存、临时文件，不需要上传
.hailo_cache/
hailo_download/

# ====================== 【DeepSeek大模型超大文件 全部忽略不上传Git】======================
# 模型文件体积几个GB，绝对不能上传GitHub仓库，只保存下载脚本
models/
*.bin
*.safetensors
*.gguf
*.pth

# ====================== 【树莓派系统专属临时文件 忽略不上传】======================
# 系统交换分区、挂载临时文件
/swapfile
.mount
